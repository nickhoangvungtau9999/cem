<%- include('../partials/header', { title, currentPath }) %>

<h1>Employees</h1>
<p class="subtitle">Personal info &amp; work history.</p>

<div class="card">
  <div style="display:flex; gap:8px;">
    <input type="text" id="emp-search" placeholder="Search by ID, name, position..." style="flex:1;">
    <select id="emp-status">
      <option value="">All statuses</option>
      <option value="Active">Active</option>
      <option value="Inactive">Inactive</option>
    </select>
  </div>
</div>

<div class="card">
  <table id="emp-table">
    <thead>
      <tr><th>ID</th><th>Name</th><th>Position</th><th>Rank</th><th>Pickup point</th><th>Status</th></tr>
    </thead>
    <tbody><tr><td colspan="6" class="empty-state">Loading...</td></tr></tbody>
  </table>
</div>

<script src="/js/employees.js"></script>
<%- include('../partials/footer') %>
